{
  "name": "minimemo",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.yourname.minimemo",
    "productName": "minimemo",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/images/bok.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/images/bok.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
